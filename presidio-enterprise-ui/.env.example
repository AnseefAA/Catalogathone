# Presidio Enterprise UI - Environment Configuration

# API Endpoints
VITE_ANALYZER_URL=http://localhost:3001
VITE_ANONYMIZER_URL=http://localhost:3002
VITE_API_BASE_URL=/api

# Application Settings
VITE_APP_NAME=Presidio Enterprise
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_BATCH_PROCESSING=true
VITE_ENABLE_MULTI_CLUSTER=true
VITE_ENABLE_COMPLIANCE_REPORTS=true

# Default Configuration
VITE_DEFAULT_LANGUAGE=en
VITE_DEFAULT_SCORE_THRESHOLD=0.5
VITE_MAX_FILE_SIZE_MB=100

# Monitoring
VITE_METRICS_REFRESH_INTERVAL=30000
VITE_ENABLE_ANALYTICS=false

# Security
VITE_SESSION_TIMEOUT=3600000
VITE_ENABLE_AUDIT_LOGGING=true